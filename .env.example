KEYCLOAK_ISSUER=http://localhost:8080/realms/ptvn
KEYCLOAK_AUDIENCE=agent-gateway
KEYCLOAK_CLIENT_ID=agent-frontend
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

ORCH_URL=http://localhost:8001

# Agent service registry used by the orchestrator. Add new agents here as
# `agent-id=base-url` pairs; each agent exposes /.well-known/agent-card.
AGENT_SERVICES=world-agent=http://localhost:8004,procurement-agent=http://localhost:8005
AGENT_CONNECT_TIMEOUT_SECONDS=5
AGENT_READ_TIMEOUT_SECONDS=60

# MCP service registry used by the orchestrator. Add developer-built MCP
# servers here as `server-id=base-url` pairs; each server exposes
# /.well-known/mcp-card and a JSON-RPC /mcp endpoint (initialize, tools/list,
# tools/call). See docs/mcp-services.md.
MCP_SERVICES=world-mcp=http://localhost:8010,procurement-mcp=http://localhost:8011
MCP_CONNECT_TIMEOUT_SECONDS=5
MCP_READ_TIMEOUT_SECONDS=30

# Data planes the example MCP servers delegate their reads to; the MCP
# services themselves hold no database credentials.
WORLD_DATA_PLANE_URL=http://localhost:8006
PROCUREMENT_DATA_PLANE_URL=http://localhost:8007

# Virtual supervisor agent served by the orchestrator itself. Runs sent to this
# agent id are classified (LiteLLM with keyword fallback): general questions
# are answered directly, procurement/world questions are delegated to the
# matching agent service. Casbin must grant `agent:<id>` invoke to use it.
ROUTER_AGENT_ID=assistant

# Tool-broker callback API for long-running (action=async) agents. Agents call
# the orchestrator back at ORCHESTRATOR_CALLBACK_URL (defaults to ORCH_URL) to
# request tools, poll results, and complete the run. Set AGENT_CALLBACK_TOKEN
# to a shared secret to require it on every callback; empty disables the check.
#ORCHESTRATOR_CALLBACK_URL=http://localhost:8001
AGENT_CALLBACK_TOKEN=
TOOL_BROKER_POLL_INTERVAL_SECONDS=0.5
TOOL_BROKER_TIMEOUT_SECONDS=120

# Per-agent data planes used by the SQL worker to route each query to the data
# access layer that owns its database (`database=base-url` pairs). Each plane
# holds credentials for only its own database.
DATA_PLANES=world=http://localhost:8006,procurement=http://localhost:8007

# Gateway traffic and resilience controls.
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RUN_RATE_PER_MINUTE=30
GATEWAY_RUN_RATE_BURST=10
GATEWAY_MAX_MESSAGE_CHARS=4000
GATEWAY_IDEMPOTENCY_TTL_SECONDS=600
GATEWAY_UPSTREAM_CONNECT_TIMEOUT_SECONDS=5
GATEWAY_UPSTREAM_READ_TIMEOUT_SECONDS=60
GATEWAY_BREAKER_FAILURE_THRESHOLD=5
GATEWAY_BREAKER_RESET_SECONDS=30
GATEWAY_JWT_LEEWAY_SECONDS=30

KAFKA_BOOTSTRAP=localhost:9092

LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MODEL=your-litellm-model-name
LITELLM_API_KEY=your-litellm-secret-key
LITELLM_TIMEOUT_SECONDS=30

LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-b654dc21-3f47-4379-a0ea-2e08a8abd6b9
LANGFUSE_SECRET_KEY=sk-lf-806ab9fd-990b-41be-84e6-af8f5f4888cf
LANGFUSE_BASE_URL=http://langfuse-web:3000
LANGFUSE_PUBLIC_URL=http://localhost:3001
